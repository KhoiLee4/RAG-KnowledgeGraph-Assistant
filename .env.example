# ============================================================
# Sao chép file này ở thư mục gốc repo: copy .env.example .env
# Backend FastAPI đọc file này (không dùng backend/.env)
# ============================================================

# ── Gemini AI ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Google OAuth2 & Drive (Web application — multi-user) ───
# Google Cloud Console → OAuth 2.0 Client ID → Web application
# Authorized redirect URI: http://localhost:3000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string
GOOGLE_TOKENS_DIR=tokens
# Legacy (Desktop OAuth — không dùng nữa):
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.pickle

# ── Neo4j ──────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=yourpassword

# ── ChromaDB ───────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_DEFAULT_COLLECTION=knowledge_base

# ── Tesseract OCR (Windows) ────────────────────────────────
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_LANG=vie+eng

# ── Chunking ───────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Retrieval (hybrid vector + keyword) ────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.12
RETRIEVAL_VECTOR_WEIGHT=0.80
RETRIEVAL_KEYWORD_WEIGHT=0.20
RETRIEVAL_CANDIDATE_MULTIPLIER=3

# ── GraphRAG ───────────────────────────────────────────────
GRAPH_ENABLED=true
GRAPH_ALPHA=0.7
GRAPH_BUILD_ON_INDEX=true
GRAPH_ENTITY_BATCH_SIZE=8
GRAPH_ENTITY_BATCH_PAUSE=3.0

# ── Entity normalization ─────────────────────────────────────
ENTITY_FUZZY_THRESHOLD=85
ENTITY_ALIAS_MAP_PATH=data/entity_aliases.json

# ── Community detection ──────────────────────────────────────
GRAPH_BUILD_COMMUNITIES=true
COMMUNITY_MIN_SIZE=3
COMMUNITY_SUMMARY_PAUSE=2.0
COMMUNITY_RELATED_WEIGHT=2.0
COMMUNITY_COOCCUR_WEIGHT=1.0

# ── Hybrid retrieval ───────────────────────────────────────────
RETRIEVAL_CONTEXT_MAX_CHARS=8000

# ── Indexing throttle (tránh 429 Gemini) ───────────────────
INDEX_FILE_PAUSE=5.0
INDEX_QUOTA_COOLDOWN=45.0
INDEX_QUOTA_MAX_RETRIES=2
EMBED_BATCH_PAUSE=2.5

# ── FastAPI ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8081
APP_DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
